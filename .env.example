# Required
BOT_TOKEN=your-telegram-bot-token

# Optional admin chat/user IDs
ADMIN_ONE_ID=
ADMIN_TWO_ID=

# Bot persistence
BLACKLIST_DB_PATH=.bot_state/blacklist.sqlite3

# Parser persistence
STATE_FILE_PATH=data/state.json
SNAPSHOT_INTERVAL_SEC=60

# Market data sources
SPOT_WS_URL=wss://wbs-api.mexc.com/ws
FUT_WS_URL=wss://contract.mexc.com/edge
SPOT_TICKERS_CHANNEL=spot@public.miniTickers.v3.api.pb@UTC+8
FUT_TICKERS_CHANNEL=sub.tickers
QUOTE=USDT

# Connectivity
PING_INTERVAL_SEC=15
RECONNECT_DELAY_SEC=5

# Alert thresholds
MIN_VOLUME_24H_USD=100000
OPEN_THRESHOLD=1.5
CLOSE_THRESHOLD=0.5
DEEPEN_TRIGGER=1.5
OPEN_DEBOUNCE=3
CLOSE_DEBOUNCE=5
DEEPEN_DEBOUNCE=3
